# ── Seguridad bloquear ejecución de scripts en /uploads/ ──
<FilesMatch "\.(php|php3|php4|php5|phtml|pl|py|cgi|sh|rb|asp|aspx|jsp)$"> 
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Deny,Allow
        Deny from all
    </IfModule>
</FilesMatch>